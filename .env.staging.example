# Staging stack configuration
# Copy to .env.staging and fill in real values before running staging deploys.

# Soroban / chain
SOROBAN_RPC=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
FRIENDBOT_URL=https://friendbot.stellar.org
POKER_TABLE_CONTRACT=C...
ZK_VERIFIER_CONTRACT=C...
COMMITTEE_REGISTRY_CONTRACT=C...
GAME_HUB_CONTRACT=C...
TOKEN_CONTRACT=C...
TABLE_ID=0
ONCHAIN_TABLE_ID=0

# Coordinator signing identity
COMMITTEE_SECRET=S...
COMMITTEE_IDENTITY=committee-staging
COMMITTEE_ADDRESS=G...

# Seeded staging test players used by integration checks
PLAYER1_ADDRESS=G...
PLAYER1_IDENTITY=player1-staging
PLAYER2_ADDRESS=G...
PLAYER2_IDENTITY=player2-staging

# Coordinator / frontend public URLs
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8080
NEXT_PUBLIC_STELLAR_EXPERT_BASE_URL=https://stellar.expert/explorer/testnet
STAGING_FRONTEND_URL=http://localhost:3000

# Container image tags (optional)
STAGING_COORDINATOR_IMAGE=stellpoker/coordinator:staging
STAGING_MPC_NODE_IMAGE=stellpoker/mpc-node:staging
STAGING_FRONTEND_IMAGE=stellpoker/frontend:staging

# Host port overrides (optional)
STAGING_COORDINATOR_PORT=8080
STAGING_FRONTEND_PORT=3000
STAGING_NODE0_PORT=8101
STAGING_NODE1_PORT=8102
STAGING_NODE2_PORT=8103
